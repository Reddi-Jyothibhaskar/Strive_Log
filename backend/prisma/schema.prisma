generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subject {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  created_at    DateTime
  is_active     Boolean

  dailyEntries  DailyEntry[]
  topics        Topic[]
  tempTopics    TempTopic[]

  @@map("subjects")
}

model DailyEntry {
  id         Int      @id @default(autoincrement())
  subject_id Int
  study_date DateTime

  subject    Subject  @relation(fields: [subject_id], references: [id])

  @@map("daily_entries")
}

model TempTopic {
  id         Int   @id @default(autoincrement())
  subject_id Int
  name       String   @db.VarChar(150)
  created_at DateTime @default(now()) @db.Timestamp(6)

  subject    Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@map("temp_topics")
}

model Topic {
  id               Int   @id @default(autoincrement())
  subject_id       Int
  name             String   @db.VarChar(150)
  first_studied_at DateTime @db.Date
  last_studied_at  DateTime @db.Date
  frequency        Int      @default(1)

  subject          Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([subject_id, name], map: "uniq_topic_per_subject")
  @@map("topics")
}